APP_NAME=Jingle Engine
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://<user>:<password>@<neon-host>.neon.tech/<db-name>

SECRET_KEY=change-this-to-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

RESET_TOKEN_EXPIRE_MINUTES=30
RESET_RESEND_COOLDOWN_SECONDS=60

# SMTP is OPTIONAL. It powers only the password-reset email
# (POST /auth/forgot-password). Leave SMTP_HOST blank to run without email;
# the app still boots and forgot-password responds normally, it just won't send.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@jingle-engine.local
SMTP_FROM_NAME=Jingle Engine
SMTP_USE_TLS=true

REDIS_URL=redis://localhost:6379/0

UPLOAD_DIR=uploads/reference_audio
PUBLIC_BASE_URL=http://localhost:8000
MAX_UPLOAD_SIZE_MB=20
ALLOWED_AUDIO_EXTENSIONS=.mp3,.wav,.ogg,.m4a,.aac
